{
  "pages": [
    {
      "path": "pages/index/index",
      "style": {
        "navigationBarTitleText": "AI舌诊",
        "enablePullDownRefresh": false,
        "navigationStyle": "custom"
      }
    },
    {
      "path": "pages/login/index",
      "style": {
        "navigationBarTitleText": "登录",
        "enablePullDownRefresh": false,
        "navigationStyle": "custom"
      }
    },
    {
      "path": "pages/register/index",
      "style": {
        "navigationBarTitleText": "注册",
        "enablePullDownRefresh": false,
        "navigationStyle": "custom"
      }
    },
    {
      "path": "pages/diagnosis/index",
      "style": {
        "navigationBarTitleText": "舌诊诊断",
        "enablePullDownRefresh": false,
        "navigationStyle": "custom"
      }
    },
    {
      "path": "pages/result/index",
      "style": {
        "navigationBarTitleText": "诊断结果",
        "enablePullDownRefresh": false,
        "navigationStyle": "custom"
      }
    },
    {
      "path": "pages/history/index",
      "style": {
        "navigationBarTitleText": "诊断历史",
        "enablePullDownRefresh": true,
        "navigationStyle": "custom"
      }
    },
    {
      "path": "pages/detail/index",
      "style": {
        "navigationBarTitleText": "诊断详情",
        "enablePullDownRefresh": false,
        "navigationStyle": "custom"
      }
    },
    {
      "path": "pages/profile/index",
      "style": {
        "navigationBarTitleText": "我的",
        "enablePullDownRefresh": false,
        "navigationStyle": "custom"
      }
    }
  ],
  "globalStyle": {
    "navigationBarTextStyle": "black",
    "navigationBarTitleText": "AI舌诊智能诊断",
    "navigationBarBackgroundColor": "#F8F8F8",
    "backgroundColor": "#F8F8F8",
    "backgroundTextStyle": "light",
    "enablePullDownRefresh": false
  },
  "tabBar": {
    "color": "#7A7E83",
    "selectedColor": "#667eea",
    "borderStyle": "black",
    "backgroundColor": "#ffffff",
    "list": [
      {
        "pagePath": "pages/index/index",
        "iconPath": "static/tabbar/home.png",
        "selectedIconPath": "static/tabbar/home-active.png",
        "text": "首页"
      },
      {
        "pagePath": "pages/history/index",
        "iconPath": "static/tabbar/history.png",
        "selectedIconPath": "static/tabbar/history-active.png",
        "text": "历史"
      },
      {
        "pagePath": "pages/profile/index",
        "iconPath": "static/tabbar/profile.png",
        "selectedIconPath": "static/tabbar/profile-active.png",
        "text": "我的"
      }
    ]
  },
  "easycom": {
    "autoscan": true,
    "custom": {
      "^u-(.*)": "@/uni_modules/uview-plus/components/u-$1/u-$1.vue",
      "^tongue-(.*)": "@/components/tongue-$1/tongue-$1.vue",
      "^feature-display$": "@/components/feature-display/feature-display.vue",
      "^recommendation-list$": "@/components/recommendation-list/recommendation-list.vue"
    }
  },
  "uniIdRouter": {},
  "condition": {
    "current": 0,
    "list": [
      {
        "name": "首页",
        "path": "pages/index/index",
        "query": ""
      },
      {
        "name": "登录",
        "path": "pages/login/index",
        "query": ""
      },
      {
        "name": "注册",
        "path": "pages/register/index",
        "query": ""
      },
      {
        "name": "诊断",
        "path": "pages/diagnosis/index",
        "query": ""
      },
      {
        "name": "诊断结果",
        "path": "pages/result/index",
        "query": "id"
      },
      {
        "name": "诊断详情",
        "path": "pages/detail/index",
        "query": "id"
      },
      {
        "name": "我的",
        "path": "pages/profile/index",
        "query": ""
      }
    ]
  }
}
