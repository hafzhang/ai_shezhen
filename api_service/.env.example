# AI舌诊智能诊断系统 - 环境变量配置
# Environment Variables for Tongue Diagnosis AI System
#
# 使用方法:
# 1. 复制此文件为 .env
# 2. 修改配置值
# 3. 确保 .env 文件不被提交到版本控制

# ============================================================================
# API服务配置
# ============================================================================

# API主机和端口
API_HOST=0.0.0.0
API_PORT=8000

# API文档开关
ENABLE_API_DOCS=true

# 调试模式 (生产环境请设为false)
DEBUG=false

# Mock模式 (无模型时的测试模式)
MOCK_MODE=false

# ============================================================================
# 模型配置
# ============================================================================

# 分割模型路径
SEGMENT_MODEL_PATH=models/deploy/segment_fp16/model_fp16.pdparams

# 分类模型路径
CLASSIFY_MODEL_PATH=models/deploy/classify_fp16/model_fp16.pdparams

# 是否使用FP16推理
USE_FP16=true

# 推理设备 (cpu/gpu)
INFERENCE_DEVICE=cpu

# 推理批次大小
INFERENCE_BATCH_SIZE=1

# ============================================================================
# Redis配置
# ============================================================================

# Redis主机和端口
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=your_redis_password

# Redis最大连接数
REDIS_MAX_CONNECTIONS=20

# ============================================================================
# Celery配置
# ============================================================================

# Celery Broker URL (Redis)
CELERY_BROKER_URL=redis://localhost:6379/1

# Celery Result Backend (Redis)
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Worker并发数
CELERY_WORKER_CONCURRENCY=4

# 任务超时时间 (秒)
CELERY_TASK_TIMEOUT=30

# 任务最大重试次数
CELERY_TASK_MAX_RETRIES=3

# ============================================================================
# 百度文心一言API配置
# ============================================================================

# 百度云API密钥 (从百度云控制台获取)
# BAIDU_API_KEY=your_api_key_here
# BAIDU_SECRET_KEY=your_secret_key_here

# 文心模型选择
WENXIN_MODEL=ERNIE-Speed

# API调用超时 (秒)
API_CALL_TIMEOUT=10

# ============================================================================
# 日志配置
# ============================================================================

# 日志级别 (DEBUG/INFO/WARNING/ERROR/CRITICAL)
LOG_LEVEL=INFO

# 日志文件路径
LOG_FILE_PATH=logs/api_service.log

# 是否启用审计日志
ENABLE_AUDIT_LOG=true

# 审计日志路径
AUDIT_LOG_PATH=logs/audit.log

# ============================================================================
# 监控配置 (task-5-2)
# ============================================================================

# 是否启用Prometheus指标
ENABLE_PROMETHEUS=true

# 是否启用MLflow
ENABLE_MLFLOW=false

# MLflow跟踪URI
MLFLOW_TRACKING_URI=http://localhost:5000

# 是否启用成本监控
ENABLE_COST_MONITORING=true

# 月度预算告警 (元)
MONTHLY_BUDGET_ALERT=1000.0

# 每日最大请求数
DAILY_MAX_REQUESTS=1000

# ============================================================================
# 安全和限流配置
# ============================================================================

# 每秒请求限制
RATE_LIMIT_PER_SECOND=100

# 限流突发容量
RATE_LIMIT_BURST=100

# 是否启用限流
ENABLE_RATE_LIMIT=true

# 是否启用API密钥认证
ENABLE_API_KEY_AUTH=false

# ============================================================================
# 熔断器配置 (task-4-8)
# ============================================================================

# 熔断器失败阈值
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5

# 熔断器成功阈值
CIRCUIT_BREAKER_SUCCESS_THRESHOLD=2

# 熔断器超时时间 (秒)
CIRCUIT_BREAKER_TIMEOUT=60

# 半开状态最大调用数
CIRCUIT_BREAKER_HALF_OPEN_MAX_CALLS=3

# 是否启用熔断器
ENABLE_CIRCUIT_BREAKER=true

# ============================================================================
# 重试配置 (task-4-8)
# ============================================================================

# 最大重试次数
RETRY_MAX_ATTEMPTS=3

# 基础延迟 (秒)
RETRY_BASE_DELAY=1.0

# 最大延迟 (秒)
RETRY_MAX_DELAY=10.0

# 是否启用抖动
RETRY_ENABLE_JITTER=true

# 是否启用重试
ENABLE_RETRY=true

# ============================================================================
# 本地规则库兜底配置
# ============================================================================

# 是否启用规则库兜底
ENABLE_RULE_BASED_FALLBACK=true

# 规则库配置文件路径
RULE_BASED_CONFIG_PATH=api_service/config/rule_based_config.json

# ============================================================================
# 数据保留配置
# ============================================================================

# 数据保留天数
DATA_RETENTION_DAYS=180

# ============================================================================
# ELK Stack日志收集配置 (task-5-3)
# ============================================================================

# 是否启用ELK日志收集
ENABLE_ELK_LOGGING=false

# Elasticsearch地址
ELASTICSEARCH_HOSTS=http://localhost:9200

# Elasticsearch用户名
ELASTICSEARCH_USER=elastic

# Elasticsearch密码
ELASTICSEARCH_PASSWORD=changeme

# 是否使用SSL连接Elasticsearch
ELASTICSEARCH_SSL=false

# 是否验证SSL证书
ELASTICSEARCH_VERIFY_SSL=true

# ELK环境标识 (production/staging/development)
ELK_ENVIRONMENT=production

# ============================================================================
# 性能优化配置 (task-5-1)
# ============================================================================

# 是否启用缓存
ENABLE_CACHE=true

# 缓存TTL (秒, 默认24小时)
CACHE_TTL_SECONDS=86400

# 缓存目标命中率
CACHE_TARGET_HIT_RATE=0.50
