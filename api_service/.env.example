# ==============================================================================
# AI舌诊智能诊断系统 - 环境变量配置模板
# ==============================================================================
# 说明：复制此文件为 .env 并填入实际配置值
# 注意：.env 文件包含敏感信息，不应提交到版本控制系统
# ==============================================================================

# ==============================================================================
# 百度云文心一言 API 配置
# ==============================================================================
# 获取方式：访问 https://cloud.baidu.com/product/wenxinworkshop
# 1. 注册/登录百度云账号
# 2. 开通千帆大模型平台服务
# 3. 创建应用获取 API Key 和 Secret Key

# 百度云 API Key（必填）
BAIDU_API_KEY=your_api_key_here

# 百度云 Secret Key（必填）
BAIDU_SECRET_KEY=your_secret_key_here

# 文心一言模型选择（可选，默认：ERNIE-Speed）
# 可选值：ERNIE-Speed, ERNIE-Speed-128K, ERNIE-Lite, ERNIE-Turbo, ERNIE-4.0
WENXIN_MODEL=ERNIE-Speed

# API 端点（可选，默认为官方端点）
WENXIN_API_BASE=https://aip.baidubce.com/rpc/2.0/ai_custom/v1/wenxinworkshop/chat

# ==============================================================================
# 服务配置
# ==============================================================================
# API 服务监听地址
API_HOST=0.0.0.0

# API 服务监听端口
API_PORT=8000

# API 版本
API_VERSION=v1

# ==============================================================================
# Redis 配置（用于异步任务队列和缓存）
# ==============================================================================
# Redis 主机地址
REDIS_HOST=localhost

# Redis 端口
REDIS_PORT=6379

# Redis 数据库编号
REDIS_DB=0

# Redis 密码（可选）
# REDIS_PASSWORD=your_redis_password

# Redis 连接池大小
REDIS_MAX_CONNECTIONS=20

# ==============================================================================
# Celery 配置（异步任务队列）
# ==============================================================================
# Celery Broker URL（使用 Redis）
CELERY_BROKER_URL=redis://localhost:6379/1

# Celery Result Backend
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Celery Worker 并发数
CELERY_WORKER_CONCURRENCY=4

# Celery 任务超时时间（秒）
CELERY_TASK_TIMEOUT=30

# Celery 任务重试次数
CELERY_TASK_MAX_RETRIES=3

# ==============================================================================
# 模型推理配置
# ==============================================================================
# 分割模型路径
SEGMENT_MODEL_PATH=models/deploy/segment_fp16/model_fp16.pdparams

# 分类模型路径
CLASSIFY_MODEL_PATH=models/deploy/classify_fp16/model_fp16.pdparams

# 推理设备（cpu/gpu）
INFERENCE_DEVICE=cpu

# 推理批大小
INFERENCE_BATCH_SIZE=1

# ==============================================================================
# 文心一言 Prompt 配置
# ==============================================================================
# System Prompt 文件路径
SYSTEM_PROMPT_PATH=api_service/prompts/system_prompt.txt

# Few-shot 示例文件路径
FEW_SHOT_EXAMPLES_PATH=api_service/prompts/few_shot_examples.json

# User Prompt 模板路径
USER_PROMPT_TEMPLATE_PATH=api_service/prompts/user_prompt_template.py

# ==============================================================================
# 诊断配置
# ==============================================================================
# 启用本地规则库兜底
ENABLE_RULE_BASED_FALLBACK=true

# API 调用超时时间（秒）
API_CALL_TIMEOUT=10

# 兜底规则库路径
RULE_BASED_CONFIG_PATH=api_service/config/rule_based_config.json

# ==============================================================================
# 成本控制配置
# ==============================================================================
# 月度预算告警阈值（元）
MONTHLY_BUDGET_ALERT=1000

# 单日最大调用量
DAILY_MAX_REQUESTS=1000

# 成本监控启用状态
ENABLE_COST_MONITORING=true

# ==============================================================================
# 监控和日志配置
# ==============================================================================
# 日志级别（DEBUG, INFO, WARNING, ERROR, CRITICAL）
LOG_LEVEL=INFO

# 日志文件路径
LOG_FILE_PATH=logs/api_service.log

# MLflow 跟踪启用状态
ENABLE_MLFLOW=true

# MLflow 跟踪服务器
MLFLOW_TRACKING_URI=http://localhost:5000

# ==============================================================================
# 安全配置
# ==============================================================================
# CORS 允许的源（逗号分隔）
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# API 密钥认证启用状态
ENABLE_API_KEY_AUTH=true

# 速率限制（每秒请求数）
RATE_LIMIT_PER_SECOND=100

# ==============================================================================
# 合规和隐私配置
# ==============================================================================
# 数据留存期限（天）
DATA_RETENTION_DAYS=180

# 审计日志启用状态
ENABLE_AUDIT_LOG=true

# 审计日志路径
AUDIT_LOG_PATH=logs/audit.log

# ==============================================================================
# 开发/调试配置
# ==============================================================================
# 调试模式（生产环境请设置为 false）
DEBUG=false

# 开启 API 文档（Swagger/OpenAPI）
ENABLE_API_DOCS=true

# Mock 模式（使用模拟数据，不调用真实 API）
MOCK_MODE=false
