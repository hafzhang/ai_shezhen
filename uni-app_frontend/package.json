{
  "name": "shezhen-uni-app",
  "version": "1.0.0",
  "description": "AI舌诊智能诊断系统 - uni-app前端",
  "type": "module",
  "scripts": {
    "dev:h5": "vite --mode h5",
    "dev:mp-weixin": "vite --mode mp-weixin",
    "dev:mp-toutiao": "vite --mode mp-toutiao",
    "build:h5": "vite build --mode h5",
    "build:mp-weixin": "vite build --mode mp-weixin",
    "build:mp-toutiao": "vite build --mode mp-toutiao",
    "type-check": "vue-tsc --noEmit",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report"
  },
  "dependencies": {
    "pinia": "^2.1.7",
    "pinia-plugin-persistedstate": "^3.2.1",
    "uview-plus": "^3.7.13",
    "vue": "^3.4.21",
    "vue-i18n": "^11.2.8",
    "vue-router": "^4.2.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.1",
    "@types/node": "^20.11.19",
    "@vitejs/plugin-vue": "^5.0.4",
    "@vitejs/plugin-vue-jsx": "^5.1.4",
    "@vue/tsconfig": "^0.5.1",
    "sass": "^1.71.1",
    "typescript": "^5.3.3",
    "vite": "5.1.4",
    "vue-tsc": "^1.8.27"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
